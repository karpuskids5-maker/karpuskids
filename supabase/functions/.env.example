# Supabase Edge Functions — Environment Variables
# Copy this to Supabase Dashboard → Settings → Edge Functions → Secrets
# DO NOT commit actual values to git

# Supabase (auto-provided by Supabase, but needed for inter-function calls)
SUPABASE_URL=https://wwnfonkvemimwiqjpkij.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend (email service) — get from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email sender (must be verified domain in Resend)
FROM_EMAIL=Karpus Kids <avisos@karpuskids.com>

# OneSignal (push notifications) — get from onesignal.com
ONESIGNAL_APP_ID=47ce2d1e-152e-4ea7-9ddc-8e2142992989
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here
